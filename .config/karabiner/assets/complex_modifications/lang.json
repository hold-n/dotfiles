{
  "title": "Change keyboard layout on cmd press",
  "rules": [
    {
      "description": "Changes input to Russian on Caps lock, to English on right shift",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "caps_lock",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "key_code": "caps_lock"
            }
          ],
          "to_if_alone": [
            {
              "select_input_source": {
                "input_source_id": "^com.apple.keylayout.RussianWin$"
              }
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "right_shift",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "key_code": "right_shift"
            }
          ],
          "to_if_alone": [
            {
              "select_input_source": {
                "input_source_id": "^com.apple.keylayout.US$"
              }
            }
          ]
        }
      ]
    }
  ]
}
